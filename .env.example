NODE_ENV=development
CLIENT_URL=http://localhost:5173
PORT=5000

# Legacy Mongo-backed AgriNexus modules
MONGODB_URI=mongodb://127.0.0.1:27017/agrinexus
AUTH_JWT_SECRET=replace_with_a_long_random_secret
JWT_EXPIRES_IN=7d

# AgroSense relational and time-series stack
POSTGRES_URL=postgresql://agrosense:agrosense@localhost:5432/agrosense?schema=public
REDIS_URL=redis://127.0.0.1:6379
INFLUX_URL=http://127.0.0.1:8086
INFLUX_TOKEN=agrosense-token
INFLUX_ORG=agrosense
INFLUX_BUCKET=agrosense

# AI bridge options
MATLAB_BRIDGE_MODE=hybrid
MATLAB_EXECUTABLE=
PYTHON_INFERENCE_URL=http://127.0.0.1:8001
AGROSENSE_DATA_MODE=hybrid
AGROSENSE_REPORT_BASE_URL=http://localhost:5000/generated-reports

# Optional notifications
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=alerts@agronexus.local
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
ALERT_SMS_TO=

# Existing AI providers
GEMINI_API_KEY=
GROQ_API_KEY=
GROQ_VISION_MODEL=meta-llama/llama-4-scout-17b-16e-instruct
OLLAMA_URL=http://127.0.0.1:11434
OLLAMA_VISION_MODEL=llava:latest
AI_MODE=gemini
