VITE_API_ORIGIN=https://your-api-host.example.com
# Optional if your API v1 path is not `${VITE_API_ORIGIN}/api/v1`
VITE_API_V1_BASE=https://your-api-host.example.com/api/v1
# Optional for realtime sensor streams. Defaults to VITE_API_ORIGIN converted to ws/wss.
VITE_WS_ORIGIN=wss://your-api-host.example.com
